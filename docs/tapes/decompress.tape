# VHS tape: fqxv decompress (lossless restore, with run summary)
Output docs/images/decompress.gif

Set Shell "bash"
Set FontFamily "FiraCode Nerd Font"
Set FontSize 16
Set Width 1200
Set Height 340
Set LetterSpacing 0
Set LineHeight 1.2
Set Padding 20
Set Theme "Dracula"
Set MarginFill "#fe00fe"
Set WindowBar Colorful
Set Margin 20
Set BorderRadius 10

Type "fqxv decompress demo.fqxv -o restored.fastq"
Enter
Sleep 4s
