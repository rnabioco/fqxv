# VHS tape: fqxv compress (shows the run summary — ratio + throughput)
Output docs/images/compress.gif

Set Shell "bash"
Set FontFamily "Source Code Pro"
Set FontSize 16
Set Width 1200
Set Height 340
Set LetterSpacing 0
Set LineHeight 1.2
Set Padding 20
Set Theme "Dracula"
Set WindowBar Colorful

Type "fqxv compress demo.fastq.gz -o demo.fqxv"
Enter
Sleep 4s
