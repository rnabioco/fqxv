# VHS tape: fqxv info (container metadata + per-stream sizes)
Output docs/images/info.gif

Set Shell "bash"
Set FontFamily "FiraCode Nerd Font"
Set FontSize 16
Set Width 1000
Set Height 560
Set LetterSpacing 0
Set LineHeight 1.2
Set Padding 20
Set Theme "Dracula"
Set MarginFill "#fe00fe"
Set WindowBar Colorful
Set Margin 20
Set BorderRadius 10

Type "fqxv info demo.fqxv"
Enter
Sleep 4s
