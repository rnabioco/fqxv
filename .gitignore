/target
Cargo.lock.orig
**/*.rs.bk

# zensical docs build output
/site
/.zensical

# pixi (single root manifest; lockfile IS committed for reproducibility, env dir ignored)
/.pixi

# benchmark data + outputs live on scratch, never in the repo
/bench/data
/bench/results
*.fastq
*.fastq.gz
*.fqxv
# Slurm job logs. submit_parallel.sh routes these to the results dir, but a
# directly-submitted sbatch still writes to the submission dir — keep them out
# of git status either way.
fqxv-*.out
slurm-*.out

# Python bindings: virtualenvs, caches, and wheel build outputs
.venv/
__pycache__/
*.pyc
.pytest_cache/
/crates/fqxv-python/dist
*.egg-info/
# `maturin develop` drops the compiled extension into the mixed-layout package dir.
/crates/fqxv-python/python/fqxv/_fqxv*.so

# editor/OS cruft
.DS_Store
*.swp
/.idea
/.vscode
perf.data*
flamegraph.svg

# claude
/.claude
.fqxv-build.lock
